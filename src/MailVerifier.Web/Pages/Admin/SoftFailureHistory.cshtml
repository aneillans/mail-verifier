@page
@model MailVerifier.Web.Pages.Admin.SoftFailureHistoryModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Soft Failure History";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-clock-history me-2"></i>Soft Failure History</h1>
        <a asp-page="/Admin/SoftFailures" class="btn btn-outline-secondary">
            <i class="bi bi-cloud-upload me-1"></i>Uploads
        </a>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <form method="get" class="d-flex gap-2">
                <input type="email"
                       name="q"
                       value="@Model.Q"
                       class="form-control font-monospace"
                       placeholder="recipient@example.com"
                       autofocus
                       required />
                <button type="submit" class="btn btn-primary text-nowrap">
                    <i class="bi bi-search me-1"></i>Inspect
                </button>
            </form>
            <div class="form-text">
                Search an active soft-failure recipient to inspect all recorded failure events over time.
            </div>
        </div>
    </div>

    @if (Model.Searched)
    {
        @if (Model.Recipient == null)
        {
            <div class="alert alert-info">
                No active soft-failure recipient found for <strong class="font-monospace">@Model.Q</strong>.
            </div>
        }
        else
        {
            <div class="row g-3 mb-3">
                <div class="col-md-4">
                    <div class="card h-100">
                        <div class="card-body">
                            <div class="text-muted small">Recipient</div>
                            <div class="fw-semibold font-monospace">@Model.Recipient.EmailAddress</div>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card h-100">
                        <div class="card-body">
                            <div class="text-muted small">Last Seen</div>
                            <div class="fw-semibold">@Model.Recipient.LastSeenAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</div>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card h-100">
                        <div class="card-body">
                            <div class="text-muted small">Total Events</div>
                            <div class="display-6">@Model.Recipient.EventCount</div>
                        </div>
                    </div>
                </div>
            </div>

            @if (!Model.Events.Any())
            {
                <div class="alert alert-info">No soft-failure events were found for this recipient.</div>
            }
            else
            {
                <div class="card">
                    <div class="card-header d-flex justify-content-between">
                        <strong>Event Timeline</strong>
                        <span class="text-muted small">Newest first</span>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-sm table-hover mb-0 align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Recorded</th>
                                    <th>Error Code</th>
                                    <th>Response</th>
                                    <th>Upload Batch</th>
                                    <th>Uploaded By</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in Model.Events)
                                {
                                    <tr>
                                        <td>@row.RecordedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</td>
                                        <td>
                                            @if (string.IsNullOrWhiteSpace(row.ErrorCode))
                                            {
                                                <span class="text-muted">—</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">@row.ErrorCode</span>
                                            }
                                        </td>
                                        <td style="max-width: 520px;">
                                            @if (string.IsNullOrWhiteSpace(row.Response))
                                            {
                                                <span class="text-muted">—</span>
                                            }
                                            else
                                            {
                                                <span class="small">@row.Response</span>
                                            }
                                        </td>
                                        <td>
                                            <div>#@row.UploadBatchId</div>
                                            <div class="small text-muted">@(row.UploadFileName ?? "Unknown file")</div>
                                            <div class="small text-muted">@row.UploadedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</div>
                                        </td>
                                        <td class="small">@row.UploadedByName</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        }
    }
</div>
