@page "{id:int}"
@model MailVerifier.Web.Pages.Jobs.JobSqlScriptModel
@{
    Layout = "_Layout";
    ViewData["Title"] = $"Job #{Model.Job?.Id} SQL Script";
}

<div class="container py-4">
    @if (Model.Job == null)
    {
        <div class="alert alert-warning">Job not found.</div>
        <a asp-page="/Jobs/Index" class="btn btn-secondary">Back to Jobs</a>
    }
    else
    {
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h1>Generate SQL for Job #@Model.Job.Id</h1>
                @if (!string.IsNullOrWhiteSpace(Model.Job.Name))
                {
                    <p class="text-muted mb-0">@Model.Job.Name</p>
                }
            </div>
            <div class="d-flex gap-2">
                <a asp-page="/Jobs/Details" asp-route-id="@Model.Job.Id" class="btn btn-outline-primary">Back to Details</a>
                <a asp-page="/Jobs/Index" class="btn btn-outline-secondary">Back to Jobs</a>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">SQL Template</h5>
            </div>
            <div class="card-body">
                <p class="text-muted small">Use <code>%emailaddress%</code> and optional <code>%verified%</code> (rendered as <code>1</code> or <code>0</code>) in your template.</p>
                <div class="mb-3">
                    <label for="sqlTemplate" class="form-label fw-bold">Template</label>
                    <input type="text" class="form-control font-monospace" id="sqlTemplate"
                           value="INSERT INTO Verified ([EmailAddress], [Verified]) VALUES ('%emailaddress%', %verified%)"
                           placeholder="INSERT INTO Verified ([EmailAddress], [Verified]) VALUES ('%emailaddress%', %verified%)" />
                </div>
                <div class="mb-3">
                    <label for="includeMode" class="form-label fw-bold">Rows To Include</label>
                    <select id="includeMode" class="form-select">
                        <option value="all">All checked emails</option>
                        <option value="verified">Only successful (verified)</option>
                        <option value="unverified">Only unsuccessful (not verified)</option>
                    </select>
                    <div class="form-text">Used when your template does not include <code>%verified%</code>.</div>
                </div>
                <div class="mb-3">
                    <label for="atRiskMode" class="form-label fw-bold">Common / At Risk Mailboxes</label>
                    <select id="atRiskMode" class="form-select">
                        <option value="exclude">Exclude entirely</option>
                        <option value="force_unverified">Include, but treat as not verified</option>
                        <option value="include" selected>Include (use original verification result)</option>
                    </select>
                </div>
                <div class="d-flex align-items-center gap-3 mb-3">
                    <button type="button" class="btn btn-primary" id="btnGenerateSql">
                        <i class="bi bi-code-slash me-2"></i>Generate SQL
                    </button>
                    @if (Model.EmailRows.Count == 0)
                    {
                        <span class="text-muted small">No checked email addresses found for this job.</span>
                    }
                    else
                    {
                        <span class="text-muted small" id="rowCountText">@Model.EmailRows.Count checked email(s) available.</span>
                    }
                </div>
                <div class="d-none" id="sqlOutputSection">
                    <div class="d-flex justify-content-between align-items-center mb-1">
                        <label class="form-label fw-bold mb-0">Generated SQL</label>
                        <button type="button" class="btn btn-sm btn-outline-secondary" id="btnCopySql">
                            <i class="bi bi-clipboard me-1"></i>Copy to Clipboard
                        </button>
                    </div>
                    <textarea id="sqlOutput" class="form-control font-monospace" rows="14" readonly></textarea>
                </div>
            </div>
        </div>
    }
</div>

@if (Model.Job != null)
{
    <script>
    (function () {
        const emailRows = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.EmailRows));
        const includeModeSelect = document.getElementById('includeMode');
        const atRiskModeSelect = document.getElementById('atRiskMode');
        const rowCountText = document.getElementById('rowCountText');

        function getEmailAddress(row) {
            return row.EmailAddress ?? row.emailAddress ?? '';
        }

        function getVerifiedFlag(row) {
            const value = row.IsVerified ?? row.isVerified;
            return Boolean(value);
        }

        function getAtRiskFlag(row) {
            const value = row.IsAtRisk ?? row.isAtRisk;
            return Boolean(value);
        }

        function getEffectiveVerifiedFlag(row, atRiskMode) {
            const isAtRisk = getAtRiskFlag(row);
            if (isAtRisk && atRiskMode === 'force_unverified') {
                return false;
            }

            return getVerifiedFlag(row);
        }

        function getFilteredRows(template) {
            const atRiskMode = atRiskModeSelect.value;
            const hasVerifiedPlaceholder = /%verified%/i.test(template);
            const rowsAfterRiskFilter = emailRows.filter(function (row) {
                return !(atRiskMode === 'exclude' && getAtRiskFlag(row));
            });

            if (hasVerifiedPlaceholder) {
                return rowsAfterRiskFilter;
            }

            const mode = includeModeSelect.value;
            if (mode === 'verified') {
                return rowsAfterRiskFilter.filter(function (row) { return getEffectiveVerifiedFlag(row, atRiskMode); });
            }

            if (mode === 'unverified') {
                return rowsAfterRiskFilter.filter(function (row) { return !getEffectiveVerifiedFlag(row, atRiskMode); });
            }

            return rowsAfterRiskFilter;
        }

        function updateRowCountHint() {
            if (!rowCountText) {
                return;
            }

            const template = document.getElementById('sqlTemplate').value || '';
            const rows = getFilteredRows(template);
            rowCountText.textContent = rows.length + ' row(s) will be included.';
        }

        document.getElementById('sqlTemplate').addEventListener('input', updateRowCountHint);
        includeModeSelect.addEventListener('change', updateRowCountHint);
        atRiskModeSelect.addEventListener('change', updateRowCountHint);
        updateRowCountHint();

        document.getElementById('btnGenerateSql').addEventListener('click', function () {
            const template = document.getElementById('sqlTemplate').value;
            if (!template.trim()) {
                return;
            }

            const rows = getFilteredRows(template);
            const atRiskMode = atRiskModeSelect.value;
            const lines = rows.map(function (row) {
                const emailAddress = getEmailAddress(row);
                const verified = getEffectiveVerifiedFlag(row, atRiskMode);

                return template
                    .replace(/%emailaddress%/gi, emailAddress)
                    .replace(/%verified%/gi, verified ? '1' : '0');
            });

            const output = document.getElementById('sqlOutput');
            output.value = lines.join('\n');
            document.getElementById('sqlOutputSection').classList.remove('d-none');
        });

        document.getElementById('btnCopySql').addEventListener('click', function () {
            const output = document.getElementById('sqlOutput');
            navigator.clipboard.writeText(output.value).then(function () {
                const btn = document.getElementById('btnCopySql');
                const original = btn.innerHTML;
                btn.innerHTML = '<i class="bi bi-check me-1"></i>Copied!';
                btn.classList.replace('btn-outline-secondary', 'btn-success');
                setTimeout(function () {
                    btn.innerHTML = original;
                    btn.classList.replace('btn-success', 'btn-outline-secondary');
                }, 2000);
            });
        });
    })();
    </script>
}
